# Gitea live integration test configuration
# Copy this file to .env and fill in the values for your test instance.
# Used by: cargo test --test live_integration_test -- --ignored

# Required
GITEA_HOST=localhost
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_USER_NAME=gitea_admin
GITEA_USER_PASS=your_password
GITEA_TOKEN_VALUE=your_personal_access_token

# Optional
GITEA_NEXT_USER_NAME=
GITEA_NEXT_USER_PASS=
GITEA_TOKEN_NAME=
GITEA_GROUP_NAME=
GITEA_REPOSITORY=
RSA_PUBLIC_KEY=
ED25519_PUBLIC_KEY=
